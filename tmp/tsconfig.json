{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "preserve",
    "lib": ["DOM", "ESNext", "dom.iterable"],
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "~/*": ["tmp/src/*"],
      "~~/*": ["tmp/theme/*"],
      "@/*": ["tmp/data/*"]
    },
    "resolveJsonModule": true,
    "types": [
      "vite/client",
      "vitepress"
    ],
    "strict": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "./*.ts",
    "./.vitepress/**/*.ts",
    "./.vitepress/**/*.vue",
    "./pages/**/*.ts",
    "./pages/**/*.vue",
    "tmp/theme/**/*.ts",
    "tmp/theme/**/*.vue",
    "tmp/src/**/*.ts",
    "tmp/src/**/*.vue"
  ],
  "exclude": ["dist", "node_modules"]
}
